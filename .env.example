# =============================================================================
# CopperPilot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# AI Provider (REQUIRED)
# ---------------------------------------------------------------------------
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ---------------------------------------------------------------------------
# Parts Supplier APIs (OPTIONAL — needed for BOM generation)
# ---------------------------------------------------------------------------
# Mouser: https://www.mouser.com/api-search/
MOUSER_API_KEY=your-mouser-api-key-here

# Digikey: https://developer.digikey.com/
DIGIKEY_CLIENT_ID=your-digikey-client-id-here
DIGIKEY_CLIENT_SECRET=your-digikey-client-secret-here

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
PORT=8000
HOST=0.0.0.0
DEBUG_MODE=false
SECRET_KEY=generate-a-strong-random-key-here

# Allowed CORS origins (comma-separated)
# Example: http://localhost:3000,http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---------------------------------------------------------------------------
# Directories
# ---------------------------------------------------------------------------
OUTPUT_ROOT_DIR=output
LOGS_DIR=logs

# ---------------------------------------------------------------------------
# Optional Services
# ---------------------------------------------------------------------------
# Redis (set USE_REDIS=true to enable)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# Database
DATABASE_URL=sqlite:///./circuit_automation.db

# ---------------------------------------------------------------------------
# Cost & Performance
# ---------------------------------------------------------------------------
COST_WARNING_THRESHOLD=1.0
MAX_API_COST_PER_REQUEST=10.0

# ---------------------------------------------------------------------------
# AI Model Overrides (OPTIONAL)
# ---------------------------------------------------------------------------
# Override any step's model without editing code.
# Default: Opus 4.6 for design, Sonnet 4.5 for supporting tasks, Haiku 4.5 for validation.
# Uncomment to override:
# MODEL_STEP_1=claude-sonnet-4-5-20250929
# MODEL_STEP_2_HIGH_LEVEL=claude-sonnet-4-5-20250929
# MODEL_STEP_3_EXTRACT_MODULES=claude-sonnet-4-5-20250929
# MODEL_STEP_3_DESIGN_MODULE=claude-opus-4-6
# MODEL_STEP_3_STAGE1_COMPONENTS=claude-opus-4-6
# MODEL_STEP_3_STAGE2_CONNECTIONS=claude-opus-4-6
# MODEL_STEP_3_FIX_CIRCUIT=claude-sonnet-4-5-20250929
# MODEL_STEP_4_SELECT_PART=claude-sonnet-4-5-20250929
# MODEL_STEP_4_OPTIMIZE_BOM=claude-sonnet-4-5-20250929
# MODEL_MODULE_CONSOLIDATION=claude-opus-4-6
# MODEL_COMPONENT_AGENT=claude-sonnet-4-5-20250929
# MODEL_CONNECTION_AGENT=claude-sonnet-4-5-20250929
# MODEL_VALIDATION_AGENT=claude-haiku-4-5-20251001
# MODEL_INTEGRATION_AGENT=claude-sonnet-4-5-20250929
# MODEL_SUPERVISOR_INTERFACE=claude-opus-4-6
# MODEL_AI_FIXER=claude-sonnet-4-5-20250929
